# Copy to .env.local and fill in from Supabase dashboard.
# Never commit real keys. Only NEXT_PUBLIC_ values are safe in the browser.
#
# Get values from: Project → Connect (top bar)  OR  Project Settings → API Keys
# Use Project URL + Publishable key (sb_publishable_...) OR legacy anon key.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
